# Optional: TMDB API Read Access Token (v4 bearer token) for episode titles.
# Get one at https://www.themoviedb.org/settings/api (free, personal use).
# If unset, the app still works and shows plain "SxxExx" labels (no titles).
TMDB_API=replace-with-tmdb-read-access-token

# Optional: enable the "mark watched" checkmark. When YAMTRACK_PASSWORD is set,
# the app logs in as you and drives Yamtrack's own episode_save endpoint (the
# app never writes the DB directly). If unset, the checkmark simply isn't shown.
YAMTRACK_PASSWORD=replace-with-your-yamtrack-password
# Optional: defaults to the sole user in the DB when unset.
# YAMTRACK_USERNAME=
# Optional: where to reach Yamtrack. Defaults to the compose service name.
# YAMTRACK_URL=http://yamtrack:8000
